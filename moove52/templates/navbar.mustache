{{!

    @template theme_moove52/navbar

    This template renders the top navbar.

    Example context (json):
    {
        "output": {
            "should_display_navbar_logo": true,
            "get_compact_logo_url": "http://placekitten.com/50/50",
            "custom_menu": "<li>..</li>",
            "page_heading_menu": "<li>..</li>",
            "search_box": "<div><input type='text'></div>",
            "navbar_plugin_output": "<div class='dropdown'>Messaging</div>",
            "user_menu": "<div class='dropdown'>John Doe</div>"
        },
        "config": {
            "wwwroot": "#",
            "homeurl": "/my/"
        },
        "sitename": "Moodle Site",
        "mobileprimarynav": [
            {
                "text": "Dashboard",
                "url": "/my",
                "isactive": true
            },
            {
                "text": "Site home",
                "url": "/",
                "isactive": false
            },
            {
                "text": "My courses",
                "url": "/course",
                "isactive": false
            }
        ]
    }
}}
<style>
    .custom_logo{
        margin-left: 12px !important;
    }
</style>
<nav class="navbar custome_navbar fixed-top navbar-expand px-2" aria-label="{{#str}}sitemenubar, admin{{/str}}">
    <a href="/new/my/" class="navbar-brand d-md-flex align-items-center m-0 me-4 p-0 aabtn">

        {{# output.should_display_logo }}
            <img src="{{output.get_logo}}" class="custom_logo logo light me-1" alt="{{sitename}}">
            {{#output.get_logo_dark}}
                <img src="{{.}}" class="custom_logo logo dark me-1" alt="{{sitename}}">
            {{/output.get_logo_dark}}
        {{/ output.should_display_logo }}
        {{^ output.should_display_logo }}
            {{{ sitename }}}
        {{/ output.should_display_logo }}
    </a>
    {{#primarymoremenu}}
        <!--<div class="primary-navigation">
            {{> core/moremenu}}
        </div> -->
    {{/primarymoremenu}}

    <ul class="navbar-nav d-none d-md-flex my-1 px-1">
        <!-- page_heading_menu -->
        {{{ output.page_heading_menu }}}
    </ul>

    <div id="usernavigation" class="navbar-nav ms-auto h-100">
        <!--{{{ output.render_darkmode_controls }}} -->

        <!--{{{ output.render_mylearning_controls }}} -->

        <!-- {{# output.search_box }}
            {{{ output.search_box }}}
            <div class="divider border-start h-75 align-self-center mx-1"></div>
        {{/output.search_box}} -->
        
        {{#langmenu}}
            <!--{{> theme_boost/language_menu }}-->
            <!-- <div class="divider border-start h-75 align-self-center mx-1"></div> -->
        {{/langmenu}}
        <style>
            .language-switcher {
                display: flex;
                align-items: center;
                gap: 12px;
            }
            
            .language-option {
                display: flex;
                align-items: center;
                gap: 8px;
                /*padding: 6px 12px;*/
                cursor: pointer;
                transition: all .3s ease;
                background: #fff;
                font-size: 14px;
                font-weight: 500;
            }
            
            .language-option input[type="radio"] {
                display: none;
            }
            .usermenu div span a{
                text-decoration: none;
                color: black;
            }
            .nav-link a{
                color: black;
                text-decoration: none;
            }
            .nav_searchbar{
                width: 200px;
                border: 1px solid gray;
                border-radius: 5px;
                padding-left: 3px;
                padding-right: 6px;
            }
        </style>
        <ul class="nav navbar-nav ml-auto">
            <li class="nav-link">
                <div class="language-switcher">
                    <label class="language-option">
                        <input type="radio" name="lang" value="sw">
                        <span class="flag">
                            <img src="{{{ config.wwwroot }}}/theme/moove52/pix/kenya.png" />
                        </span>
                        <!-- <span class="lang-name">Kiswahili</span> -->
                    </label>
                
                    <label class="language-option">
                        <input type="radio" name="lang" value="en">
                        <span class="flag">
                            <img src="{{{ config.wwwroot }}}/theme/moove52/pix/uk.png" />
                        </span>
                        <!-- <span class="lang-name">English</span> -->
                    </label>
                </div>
            </li>
            <li class="nav-link">
                <div class="btn btn-success">
                    0 Points
                </div>
            </li>
            <li class="nav-link">
                <a class="" href="{{{ config.wwwroot }}}/user/profile.php?id=2">
                    <span class="namespan">
                        {{{output.should_display_username}}}
                    </span>
                    {{#output.should_display_userrole}}
                    <span class="rolespan" style="border-left: 1.9px solid black;font-size: 16px;padding-left: 3.5px;">
                        {{{output.should_display_userrole}}}
                    </span>
                    {{/output.should_display_userrole}}
                </a>
            </li>
            <li class="nav-link">
                <a class="nav-item" href="{{{ config.wwwroot }}}/message/index.php">
                    Messages
                </a>
            </li>
            <li class="nav-link">
                <a href="#">
                    Help
                    <!-- <b class="caret"></b> -->
                </a>
            </li>
            <li class="nav-link">
                <form autocomplete="off" action="https://consistent-turquoise-porpoise.91-204-209-39.cpanel.site/search/index.php"
                    method="get" accept-charset="utf-8" class="mform d-flex flex-wrap align-items-center searchform-navbar">
                    <input type="hidden" name="context" value="1453" />
                    <div class="nav_searchbar input-group" role="group" aria-labelledby="searchgrouplabel-6a58db503af616a58db50260e54">
                        <span id="searchgrouplabel-6a58db503af616a58db50260e54" class="visually-hidden">Site-wide search</span>
                        <button type="submit" class="btn btn-submit" style="    width: 36px;display: flex;align-items: center;" data-action="submit" title="Perform search">
                            <i class="icon fa fa-magnifying-glass fa-fw" aria-hidden="true"></i>
                            <span class="visually-hidden">Perform search</span>
                        </button>
                        <input
                            style="border: 0px solid;background: white;"
                            type="text"
                            id="searchinput-6a58db503af616a58db50260e54"
                            class="form-control withclear"
                            placeholder="Search"
                            aria-label="Search"
                            name="q"
                            data-region="input"
                            autocomplete="off"
                        />
                        <label for="searchinput-6a58db503af616a58db50260e54">
                            <span class="visually-hidden">Search</span>
                        </label>
                    </div>
                </form>
            </li>
            <li class="nav-link">
                <div class="d-flex align-items-center">
                    <a href="https://consistent-turquoise-porpoise.91-204-209-39.cpanel.site/login/logout.php?sesskey={{config.sesskey}}" role="menuitem" tabindex="-1">
                        <i class="fa fa-sign-out" aria-hidden="true" style="font-size: 1.3rem;"></i>
                    </a>
                </div>
            </li>
        </ul>
        <script>
            document.querySelectorAll('input[name="lang"]').forEach(radio => {
                radio.addEventListener('change', function () {
                    const url = new URL(window.location.href);
            
                    url.searchParams.set('lang', this.value);
            
                    window.location.href = url.toString();
                });
            });
        </script>
        

        
        {{{ output.navbar_plugin_output }}}
        <!--<div class="d-flex align-items-stretch usermenu-container usermenu" data-region="usermenu">
            {{#usermenu}}
                {{> core/user_menu }}
            {{/usermenu}}
        </div> -->
        <!-- {{{ output.edit_switch }}} -->
    </div>
</nav>

